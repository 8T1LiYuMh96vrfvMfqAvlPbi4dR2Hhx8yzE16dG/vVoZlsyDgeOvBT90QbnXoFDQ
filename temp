local Actions; Actions = {
    Fishing = {
        Casted = 0;

        getRod = function()
            return Character:FindFirstChildOfClass("Tool");
        end;

        isUsable = function()
            local Tool = Character:FindFirstChildOfClass("Tool");
            return Tool and Tool:GetAttribute("isFishingRod");
        end;

        Cast = function(self)
            if not self.isUsable() then return; end;
            
            if FishingAction:InvokeServer({Goal = Vector3.new(-6447.8383, -18.4431, -7614.8584),Action = 'Throw',Bait = useBait or 'Common Fish Bait'}) then
                self.Casted = os.time();

                FishingAction:InvokeServer({ Action = 'Landed' });
                return true;
            end;
        end;

        Reel = function(self)
            if not self.isUsable() then return; end;
            local delta = os.time() - self.Casted;
            local Rod = self.getRod();
            local Max = Rod:GetAttribute("FishWaitTime").Max + (math.random(55, 60)/10);

            if delta >= Max then
                local succ; repeat succ=FishingAction:InvokeServer({ Action = 'Reel' }); task.wait(); until succ;
                FishingAction:InvokeServer({ Action = 'HookReturning' });
                FishingAction:InvokeServer({ Action = 'Cancel' });

                return true;
            end;
        end;

        Full = function(self, Loop)
            if not self.isUsable() then return; end;
            if self:Cast() then
                while self.isUsable() and task.wait() do
                    if self:Reel() then
                        break;
                    end;
                end;

                if Loop then
                    self:Full(Loop);
                end;
            end;
        end;
    };

    Abilities = { 
        Settings={};
        Current={};

        Hold=function(self, Args)
            if not Args then return; end;

            local Name = Args[1];
            self.Current[Name]=self.Current[Name] or {};
            local Creation = Skill:InvokeServer(unpack(Args));
            if Creation then
                table.insert(self.Current[Name], Creation);
            end;

            return Creation;
        end;

        Release=function(self, Name, Args)
            if (not Name) or (not Args) then return; end;
            
            local function Fire(v)
                if v:IsA('RemoteFunction') then
                    v:InvokeServer(unpack(Args));
                elseif v:IsA('RemoteEvent') then
                    v:FireServer(unpack(Args));
                end;
            end;

            local Current = self.Current[Name] or {};
            for _, R in pairs(Current) do
                if (not R) or (not R.Parent) then continue; end;

                if typeof(R) == "table" then
                    for _, v in pairs(R) do Fire(v); end;
                else
                    Fire(R);
                end;
            end;
        end;
    };

    Misc = {
        GetInv=function()
            local Raw = Inventory.Value;
            return HttpService:JSONDecode(Raw) or {};
        end;

        GetSpeed=function()
            local Speed = 47;
            local Bypass = Character:GetAttribute("SpeedBypass");
            if Bypass then
                Speed=Speed+Bypass;
            end;

            return {Speed, math.max(95, Speed)};
        end;

        GetDist=function(p1, p2)
            local function Check(p)
                if typeof(p) == "Vector3" then return p; 
                elseif typeof(p) == "CFrame" then return p.Position;
                elseif typeof(p) == "Instance" and p:IsA("BasePart") then return p.Position;
                else return p; end;
            end;

            p1, p2 = Check(p1), Check(p2);
            return (p1 - p2).Magnitude;
        end;

        Combine=function(t1,t2) 
            local nt = table.clone(t1);
            for _, v in pairs(t2) do
                table.insert(nt, v);
            end;
            return nt;
        end;

        GetNearest=function(t, checkvisible)
            if typeof(t) == "Instance" then t=t:GetChildren(); end;
            if typeof(t) ~= "table" then t=nil; end;
            
            local t=t or NPCs:GetChildren();
            local Closest, Dist = nil, math.huge
            for _, v in pairs(t) do
                if typeof(v) == "Vector3" then
                    local nDist = (HRP.Position - v).Magnitude;

                    if nDist < Dist then
                        Closest = v;
                        Dist = nDist;
                    end;
                else
                    local tHumanoid = v:FindFirstChildOfClass('Humanoid');
                    local tHRP = v:FindFirstChild('HumanoidRootPart');
                    if v:IsA("Model") and tHumanoid then
                        if v~=Character and tHRP and HRP and not v:FindFirstChildOfClass("ForceField") then
                            if checkvisible and not Actions.Misc.isVisible(tHRP) then continue; end;

                            local nDist = (HRP.Position - tHRP.Position).Magnitude;

                            if nDist < Dist then
                                Closest = v;
                                Dist = nDist;
                            end;
                        end;
                    elseif v:IsA("Part") then
                        local nDist = (HRP.Position - v.Position).Magnitude;

                        if nDist < Dist then
                            Closest = v;
                            Dist = nDist;
                        end;
                    end;
                end;
            end;

            return Closest;
        end;

        WithName=function(name, t)
            if typeof(t) == "Instance" then t=t:GetChildren(); end;
            if typeof(t) ~= "table" then t=nil; end;
            
            local t=t or NPCs:GetChildren();
            local Group = { };
            for i, v in pairs(t) do
                if v.Name:match(name) then
                    table.insert(Group, v);
                end;
            end;

            return Group;
        end;

        getnil=function(name, ty, parent)
            local parent = parent or game;
            for _, v in pairs(parent:GetDescendants()) do
                if (not name or v.Name == name) and (not ty or v:IsA(ty)) then
                    return v;
                end;
            end;
        end;

        GetTarget=function(Part)
            local Target;

            if typeof(_Target) == "string" then
                Target = Actions.Misc.getnil(_Target, "Model");
            elseif typeof(_Target) == "Instance" then
                if _Target:IsA("Player") then Target = _Target.Character; 
                elseif _Target:IsA("Model") then Target = _Target end;
            else
                Target = Actions.Misc.GetNearest(_Target, true);
            end;

            if Part then 
                local Found = Target:FindFirstChild(Part);
                Target = Found or Target.PrimaryPart; 
            end;

            return Target;
        end;

        InRange=function(t, range, part)
            if typeof(t) == "Instance" then t=t:GetChildren(); end;
            if typeof(t) ~= "table" then t=nil; end;
            
            local range=range or 10;
            local t=t or NPCs:GetChildren();
            local Group = { };
            for i, v in pairs(t) do
                local tHumanoid = v:FindFirstChildOfClass('Humanoid');
                local tHRP = v:FindFirstChild('HumanoidRootPart');

                if v~=Character and tHumanoid and tHRP and HRP then
                    local dist = (HRP.Position - tHRP.Position).Magnitude;

                    if dist < range then
                        if part then
                            local found = v:FindFirstChild(part);
                            if found then table.insert(Group, found); end;
                        else
                            table.insert(Group, v);
                        end;
                    end;
                end;
            end;

            return Group;
        end;

        isVisible = function(target)
            local targetPosition;
            if typeof(target) == "Vector3" then
                targetPosition = target;
            elseif target:IsA("Model") then
                targetPosition = target:FindFirstChild("HumanoidRootPart") or target.PrimaryPart or target:GetPivot().Position;
            elseif target:IsA("BasePart") then
                targetPosition = target.Position;
            else
                return nil;
            end;

            local direction = targetPosition - HRP.Position;

            local params = RaycastParams.new();
            params.FilterType = Enum.RaycastFilterType.Blacklist;
            params.FilterDescendantsInstances = { Character };
            params.IgnoreWater = true;

            local result = workspace:Raycast(HRP.Position, direction, params);
            return result;
        end;

        Convert = function(self, obj, origin)
            local Settings = Actions.Abilities.Settings;
            local Origin=origin or Settings["Origin"] or HRP;

            local New = {};
            if typeof(obj)=="table" then
                for i, v in pairs(obj) do
                    New[i]=self:Convert(v);
                end;
            else
                if typeof(obj) == 'CFrame' then
                    return Origin.CFrame;
                elseif typeof(obj) == 'Vector3' then
                    return Origin.Position;
                elseif typeof(obj) == 'Instance' then
                    local Nearest = Actions.Misc.GetNearest((Settings["Target"] and Settings["Target"]:GetChildren()) or nil);
                    local Target = Nearest;
                    if obj:IsA("Part") then
                        Target=Nearest:FindFirstChild("HumanoidRootPart") or Nearest.PrimaryPart;
                    end;

                    return Target;
                else
                    return obj;
                end;
            end;

            return New;
        end;
    };

    Bypass = {
        CDs = { Dash=1, Concasser=1, Geppo=.5, ['Ice Bike']=1, ['Ice Skate']=.5 }; -- Delay between uses
        Active = {};

        -- Speed Bypasses
        Dash = function()
            Events:WaitForChild("takestam"):FireServer(.5, "dash");
        end;

        Concasser = function(isClose)
            if isClose then return; end;
