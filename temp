task.spawn(function() -- Downtime
    if not Downtime then
        Downtime = 0;
    end;

    local MIN = 60
    local HOUR = 3600

    local ROGER_INTERVAL = 90 * MIN
    local MIHAWK_INTERVAL = 2 * HOUR
    local JUZ0_DELAY = 15 * MIN

    local BossState = {
        Juzo = {
            scheduled = false,
            spawned = false,
            seeking = false,
            nextSpawn = 0,
            island = Locations.Juzo
        },
        Roger = {
            scheduled = false,
            spawned = false,
            seeking = false,
            lastWindow = -1,
            island = Locations.Umi
        },
        Mihawk = {
            scheduled = false,
            spawned = false,
            seeking = false,
            lastWindow = -1,
            island = Locations.Umi
        }
    }

    local BossQueue = {}

    local function InWindow(t, interval)
        return (t % interval) < 2
    end

    local function GetWindowIndex(t, interval)
        return math.floor(t / interval)
    end

    local function BossExists(name)
        return #Actions.Misc.WithName(name) > 0
    end

    local function EnqueueBoss(name)
        if table.find(BossQueue, name) then return end
        BossState[name].scheduled = true
        BossState[name].seeking = true
        BossState[name].spawned = false
        table.insert(BossQueue, name)
    end

    local function OnBossDeath(name)
        BossState[name].scheduled = false
        BossState[name].spawned = false
        BossState[name].seeking = false
        if name == "Juzo" then
            BossState.Juzo.nextSpawn = os.time() + JUZ0_DELAY
        end
    end

    while not getgenv().ESTOP do
        RunService.Heartbeat:Wait()
        local now = os.time()

        if not BossState.Juzo.scheduled and now >= BossState.Juzo.nextSpawn then
            if BossExists("Juzo") then
                BossState.Juzo.scheduled = true
                BossState.Juzo.spawned = true
            else
                EnqueueBoss("Juzo")
            end
        end

        do
            local w = GetWindowIndex(now, ROGER_INTERVAL)
            if w ~= BossState.Roger.lastWindow and InWindow(now, ROGER_INTERVAL) then
                BossState.Roger.lastWindow = w
                if BossExists("Roger") then
                    BossState.Roger.scheduled = true
                    BossState.Roger.spawned = true
                else
                    EnqueueBoss("Roger")
                end
            end
        end

        do
            local w = GetWindowIndex(now, MIHAWK_INTERVAL)
            if w ~= BossState.Mihawk.lastWindow and InWindow(now, MIHAWK_INTERVAL) then
                BossState.Mihawk.lastWindow = w
                if BossExists("Mihawk") then
                    BossState.Mihawk.scheduled = true
                    BossState.Mihawk.spawned = true
                else
                    EnqueueBoss("Mihawk")
                end
            end
        end

        local currentBoss = BossQueue[1]
        if currentBoss and dodt and os.time() >= Downtime then
            local state = BossState[currentBoss]
            local Nearby = Actions.Misc.WithName(currentBoss)

            if #Nearby > 0 then
                state.spawned = true
                state.seeking = false
                local boss = Nearby[1]
                local tHRP = boss:FindFirstChild("HumanoidRootPart")
                if tHRP then
                    Tween:Create({Speed = Actions.Misc.GetSpeed(),Position = CFrame.lookAt(tHRP.Position + vector.create(0, tHRP.Size.Y + 6, 0),tHRP.Position ),Extra = ProcessBypass,Continue = true})
                    Actions.Combat.Attack(Actions.Misc.InRange(nil, 20, "HumanoidRootPart"))
                end
            elseif state.seeking then
                if Tween:Create({Speed = Actions.Misc.GetSpeed(),Position = state.island,Extra = ProcessBypass}) then
                    task.wait(3)
                end
            elseif state.spawned then
                table.remove(BossQueue, 1)
                OnBossDeath(currentBoss)
            end
        end
    end
end)

