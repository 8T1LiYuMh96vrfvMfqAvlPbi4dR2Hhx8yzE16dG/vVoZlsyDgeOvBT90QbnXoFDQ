            local Created = Abilities:Hold({"Concasser", { char=Character,g=vector.create(0,-200,0),nt=0,v0=vector.create(-3, 100, 2),t=1,x0=HRP.Position,en2=vector.create(-3000, -14, -6863) }});
            if Created then 
                Abilities:Release("Concasser", {{ cf=HRP.CFrame, cf2=HRP.CFrame }});
            end;
        end;

        Geppo = function()
            if not Character.Parent or not HRP then return; end;
            local Abilities = Actions.Abilities;
            Abilities:Hold({"Sky Walk", { char=Character, cf=HRP.CFrame }});
        end;

        ['Ice Bike'] = function()
            if not Character.Parent or not HRP then return; end;
            local Abilities = Actions.Abilities;
            Abilities:Hold({"Ice Bike", {['cf']=HRP.CFrame}});
        end;

        ['Ice Skate'] = function()
            if not Character.Parent or not HRP then return; end;

            local Hie = Character:FindFirstChild("Hie-Hie") or Backpack:FindFirstChild("Hie-Hie");
            if not Character:GetAttribute("HieE") and Backpack:FindFirstChild("Hie-Hie") then
                Humanoid:EquipTool(Hie);
                Character:SetAttribute("HieE", true);
            end;

            if Hie then Skate = Hie:FindFirstChild("skate"); end;
            task.spawn(function()
                for i=1, 100 do
                    Skate:FireServer(true);
                    Skate:FireServer(false);
                end;
            end);
        end;

        -- _Init, Call or wont do anything
        Process = function(self, ...)
            if activeBypass then
                for _, v in pairs(activeBypass) do
                    local Last = self.Active[v] or 0;
                    local delta = os.clock() - Last;
                    local cooldown = self.CDs[v] or 0;

                    if delta >= cooldown then
                        self[v](...);
                        self.Active[v]=os.clock();
                    end;
                end;
            end;
        end;
    };

    Combat = {
        Attack=function(Target)
            local Tool = Character:FindFirstChildOfClass('Tool')
            if not Tool then
                return
            end

            if Tool:GetAttribute('Category') ~= "Weapons" then
                return
            end

            local now = os.clock()

            if now - LastAttack < 0.3 then
                return
            end

            if now - LastAttack > 1.5 then
                Count = 0
            elseif Count >= 5 then
                return
            end

            LastAttack = now
            Count = Count + 1

            CombatRegister:InvokeServer({
                'swingsfx',
                AttackType or "Sword",
                Count,
                'Ground',
                false,
                PunchAnimation,
                2,
                2,
            })

            CombatRegister:InvokeServer({
                'damage',
                Target,
                AttackType or "Sword",
                { Count, 'Ground', AttackType or "Sword" },
                true,
                HRP.CFrame,
                aircombo = 'Ground',
            })
        end;
    };

    Gun = {
        Gun = "Rifle",
        canShoot = true,
        reloading = false,

        Fire = function(self)
            if not self.canShoot then return; end;
            local Target = Actions.Misc.GetTarget("Head");

            if not Target then return; end;
            Events:WaitForChild("CIcklcon"):FireServer("fire", {Start=HRP.CFrame, Gun=self.Gun, joe="true", Position=Target.Position});
            self.canShoot = false;
        end;

        Reload = function(self)
            if (self.canShoot) or (self.reloading) then return; end;
            self.reloading = true;
            
            if Events:WaitForChild("CIcklcon"):WaitForChild("gunFunctions"):InvokeServer("reload", {Gun=self.Gun}) then
                self.canShoot = true;
            end;

            self.reloading = false;
        end;

        Do = function(self)
            self:Reload(); self:Fire();
        end;
    }
};

local function ProcessBypass(...)
    Actions.Bypass:Process(...);
end;

local Loops = {};
local function Loop(key, value, func, d)
    if Loops[key] then 
        if not value then Loops[key]=nil; end;
        return; 
    end;

    Loops[key]=value;
    if not d then
        while Loops[key] do 
            func();
            RSV.Heartbeat:Wait();
        end;
    else
        while Loops[key] do 
            func();
            task.wait(d)
        end;
    end;
end;

