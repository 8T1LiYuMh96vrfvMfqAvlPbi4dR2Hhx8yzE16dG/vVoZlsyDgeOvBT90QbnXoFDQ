local Hooks = {};
local function AttemptHook(Instance, Method, ...)
    local Hook = Hooks[Instance];
    if Hook and Hook[1] == Method then
        return Hook[2](...) or nil;
    end;
end;

local function AddHook(Instance, Method, Response)
    return pcall(function() Hooks[Instance] = {Method, Response} end);
end;

